{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ZynML",
  "scopeName": "source.zynml",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zynml",
          "match": "//.*$"
        },
        {
          "name": "comment.block.zynml",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.zynml",
          "match": "(@)(\\w+)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.zynml" },
            "2": { "name": "entity.name.annotation.zynml" }
          }
        },
        {
          "name": "meta.annotation.with-args.zynml",
          "begin": "(@)(\\w+)(\\()",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.annotation.zynml" },
            "2": { "name": "entity.name.annotation.zynml" },
            "3": { "name": "punctuation.brackets.round.zynml" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.brackets.round.zynml" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#types" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fstring.zynml",
          "begin": "f\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.zynml" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.zynml" }
          },
          "patterns": [
            {
              "name": "meta.interpolation.zynml",
              "begin": "\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.zynml" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.zynml" }
              },
              "patterns": [
                { "include": "#keywords" },
                { "include": "#numbers" },
                { "include": "#operators" },
                { "include": "#variables" }
              ]
            },
            {
              "name": "constant.character.escape.zynml",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.zynml",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.zynml" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.zynml" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.zynml",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.zynml",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.zynml" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.zynml" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.zynml",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.zynml",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.hexadecimal.zynml",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.binary.zynml",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.octal.zynml",
          "match": "\\b0o[0-7]+\\b"
        },
        {
          "name": "constant.numeric.integer.suffixed.zynml",
          "match": "\\b\\d+(?:ms|ns|us|s|m|h|d|px|em|rem|%)?\\b"
        },
        {
          "name": "constant.numeric.integer.zynml",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.zynml",
          "match": "\\b(if|else|elif|match|case|for|while|in|return|break|continue|loop)\\b"
        },
        {
          "name": "keyword.control.async.zynml",
          "match": "\\b(async|await)\\b"
        },
        {
          "name": "storage.type.function.zynml",
          "match": "\\b(def|fn)\\b"
        },
        {
          "name": "storage.type.struct.zynml",
          "match": "\\b(struct|enum|trait|impl|type|abstract)\\b"
        },
        {
          "name": "storage.type.effect.zynml",
          "match": "\\b(effect|handler)\\b"
        },
        {
          "name": "storage.modifier.zynml",
          "match": "\\b(mut|const|extern|opaque)\\b"
        },
        {
          "name": "keyword.declaration.zynml",
          "match": "\\b(let|where|as)\\b"
        },
        {
          "name": "constant.language.boolean.zynml",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.option.zynml",
          "match": "\\b(Some|None|Ok|Err)\\b"
        },
        {
          "name": "variable.language.self.zynml",
          "match": "\\b(self|Self)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "comment": "Pipe operator",
          "name": "keyword.operator.pipe.zynml",
          "match": "\\|>"
        },
        {
          "comment": "Fat arrow (lambda)",
          "name": "keyword.operator.arrow.fat.zynml",
          "match": "=>"
        },
        {
          "comment": "Thin arrow (return type - legacy)",
          "name": "keyword.operator.arrow.thin.zynml",
          "match": "->"
        },
        {
          "comment": "Path separator",
          "name": "keyword.operator.path.zynml",
          "match": "::"
        },
        {
          "comment": "Type annotation colon",
          "name": "punctuation.separator.type.zynml",
          "match": ":"
        },
        {
          "comment": "Null coalescing",
          "name": "keyword.operator.nullcoalesce.zynml",
          "match": "\\?\\?"
        },
        {
          "comment": "Optional/unwrap",
          "name": "keyword.operator.optional.zynml",
          "match": "\\?"
        },
        {
          "comment": "Spread/range operators",
          "name": "keyword.operator.spread.zynml",
          "match": "\\.\\.\\.|\\.\\."
        },
        {
          "comment": "Equality comparison (must come before assignment)",
          "name": "keyword.operator.comparison.equality.zynml",
          "match": "==|!="
        },
        {
          "comment": "Relational comparison",
          "name": "keyword.operator.comparison.relational.zynml",
          "match": "<=|>=|<|>"
        },
        {
          "comment": "Compound assignment (must come before simple assignment)",
          "name": "keyword.operator.assignment.compound.zynml",
          "match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>="
        },
        {
          "comment": "Simple assignment",
          "name": "keyword.operator.assignment.zynml",
          "match": "="
        },
        {
          "comment": "Logical operators",
          "name": "keyword.operator.logical.zynml",
          "match": "&&|\\|\\||!"
        },
        {
          "comment": "Arithmetic operators",
          "name": "keyword.operator.arithmetic.zynml",
          "match": "\\+|-|\\*|/|%|@"
        },
        {
          "comment": "Bitwise shift (must come before < >)",
          "name": "keyword.operator.bitwise.shift.zynml",
          "match": "<<|>>"
        },
        {
          "comment": "Bitwise operators",
          "name": "keyword.operator.bitwise.zynml",
          "match": "&|\\||\\^|~"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.zynml",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|str|String|char)\\b"
        },
        {
          "name": "support.type.builtin.zynml",
          "match": "\\b(Option|Result|List|Array|HashMap|HashSet|Tensor|Audio|Model|Vector|Text|Iterator|Promise)\\b"
        },
        {
          "name": "entity.name.type.zynml",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Private function definition (starts with _)",
          "name": "meta.function.definition.private.zynml",
          "match": "\\b(def|fn)\\s+(_[a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.zynml" },
            "2": { "name": "entity.name.function.private.zynml" }
          }
        },
        {
          "comment": "Public function definition",
          "name": "meta.function.definition.zynml",
          "match": "\\b(def|fn)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.zynml" },
            "2": { "name": "entity.name.function.zynml" }
          }
        },
        {
          "comment": "Private function call (starts with _)",
          "name": "meta.function.call.private.zynml",
          "match": "\\b(_[a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.private.zynml" }
          }
        },
        {
          "comment": "Public function call",
          "name": "meta.function.call.zynml",
          "match": "\\b([a-z][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.zynml" }
          }
        },
        {
          "comment": "Private method call (starts with _)",
          "name": "meta.method.call.private.zynml",
          "match": "\\.(_[a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.method.private.zynml" }
          }
        },
        {
          "comment": "Public method call",
          "name": "meta.method.call.zynml",
          "match": "\\.([a-z][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.method.zynml" }
          }
        },
        {
          "name": "support.function.builtin.zynml",
          "match": "\\b(println|print|format|extern|load|model|compute|tensor|arange)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "comment": "Private parameter (starts with _)",
          "name": "variable.parameter.private.zynml",
          "match": "\\b(_[a-zA-Z0-9_]*)\\s*(?=:)"
        },
        {
          "comment": "Public parameter",
          "name": "variable.parameter.zynml",
          "match": "\\b([a-z][a-zA-Z0-9_]*)\\s*(?=:)"
        },
        {
          "comment": "Private variable (starts with _)",
          "name": "variable.other.private.zynml",
          "match": "\\b_[a-zA-Z0-9_]*\\b"
        },
        {
          "comment": "Public variable",
          "name": "variable.other.zynml",
          "match": "\\b[a-z][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
